{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "files": {
    "includes": [
      "src/**",
      "*.json",
      "*.ts",
      "*.tsx",
      "*.js",
      "*.jsx",
      "*.css",
      "!src-tauri/target",
      "!node_modules",
      "!dist"
    ]
  }
}
