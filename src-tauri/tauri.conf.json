{
  "package": {
    "productName": "Second Brain",
    "version": "0.1.0"
  },
  "build": {
    "beforeDevCommand": "bun run frontend:dev",
    "beforeBuildCommand": "bun run frontend:build",
    "devPath": "http://localhost:5173"
  },
  "tauri": {
    "windows": [
      {
        "title": "Second Brain",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "allowlist": {
      "fs": {
        "all": true
      },
      "shell": {
        "all": true,
        "execute": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.adamspicedev.secondbrain",
      "icon": [
        "icons/icon.png"
      ]
    }
  }
}
