{
  "name": "secondbrain",
  "version": "0.1.0",
  "description": "AI-powered second brain desktop app",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "sh ./scripts/prebuild-macos-cleanup.sh && tauri build",
    "frontend:dev": "vite",
    "frontend:build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "doctor:deps": "sh ./scripts/doctor-deps.sh",
    "biome:check": "biome check .",
    "biome:write": "biome check --write .",
    "biome:format": "biome format --write ."
  },
  "bunfig": {
    "install": {
      "peer": true
    }
  },
  "dependencies": {
    "@tauri-apps/api": "^1.5.0",
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^1.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
